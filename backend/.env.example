FLASK_APP=run.py
FLASK_ENV=development
DATABASE_URL=postgresql://user:pass@localhost/database_name
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
FLASK_PORT=5001
UPLOADS_DIRECTORY=/app/uploads
CORS_ORIGINS=http://localhost:3001,http://frontend:3001

# Crossref API Configuration
CROSSREF_API_URL=https://api.crossref.org/works/
CROSSREF_API_KEY=YOUR_CROSSREF_API_KEY

# CrossRef DEPOSIT config (separate from the read-API above). Default endpoint
# is the TEST server. Until DOCiD has a real CrossRef member account + DOI
# prefix, leave CROSSREF_DEPOSIT_ENABLED=false.
CROSSREF_DEPOSIT_URL=https://test.crossref.org/servlet/deposit
CROSSREF_SUBMISSION_DOWNLOAD_URL=https://test.crossref.org/servlet/submissionDownload
CROSSREF_DEPOSIT_LOGIN=
CROSSREF_DEPOSIT_PASSWORD=
CROSSREF_DEPOSITOR_NAME=Africa PID Alliance
CROSSREF_DEPOSITOR_EMAIL=info@africapidalliance.org
CROSSREF_DOI_PREFIX=
CROSSREF_DEPOSIT_ENABLED=false

# CSTR Configuration
CSTR_CLIENT_ID=your_cstr_client_id
CSTR_SECRET=your_cstr_secret
CSTR_PREFIX=your_cstr_prefix
CSTR_USERNAME=your_cstr_username

# Local Contexts Configuration
LC_API_KEY=your_local_contexts_api_key
LOCAL_CONTEXTS_API_BASE_URL=https://sandbox.localcontextshub.org/api/v2

# Application Configuration
APPLICATION_BASE_URL=http://localhost:3001

# CORDRA Configuration
CORDRA_BASE_URL=https://cordra.kenet.or.ke/cordra
CORDRA_USERNAME=your_cordra_username
CORDRA_PASSWORD=your_cordra_password

# Celery Configuration (optional)
CELERY_BROKER_URL=redis://redis:6379/0

# SMTP Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password_or_app_password
MAIL_DEFAULT_SENDER_NAME=AFRICA PID Alliance
MAIL_DEFAULT_SENDER_EMAIL=info@africapidalliance.org
MAIL_MAX_EMAILS=5
MAIL_DEBUG=False
DEBUG=False

# RAID Configuration
RAID_API_URL=https://api.demo.raid.org.au/raid/
RAID_TOKEN_URL=https://iam.demo.raid.org.au/realms/raid/protocol/openid-connect/token
RAID_GRANT_TYPE=password
RAID_CLIENT_ID=your_raid_client_id
RAID_CLIENT_SECRET=your_raid_client_secret
RAID_USERNAME=your_raid_username
RAID_PASSWORD=your_raid_password

# DSpace Configuration
DSPACE_BASE_URL=https://demo.dspace.org/server
DSPACE_USERNAME=
DSPACE_PASSWORD=
SCICRUNCH_API_KEY=

# DSpace Legacy Configuration (Stellenbosch University)
DSPACE_LEGACY_URL=
DSPACE_LEGACY_EMAIL=
DSPACE_LEGACY_PASSWORD=
DSPACE_LEGACY_INSTANCE_NAME=

OPENALEX_CONTACT_EMAIL=
UNPAYWALL_CONTACT_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=

# Enrichment provider credentials (Wave 1-2 integrations)
CORE_API_KEY=
CORE_API_BASE_URL=https://api.core.ac.uk/v3
OPENAIRE_API_BASE_URL=https://graph.openaire.eu/api
OPENCITATIONS_ACCESS_TOKEN=
LENS_SCHOLAR_API_KEY=
LENS_PATENT_API_KEY=
LENS_API_BASE_URL=https://api.lens.org

# BASE (Bielefeld Academic Search Engine) — apply at base-search.net (1-4 week approval)
BASE_API_KEY=
BASE_API_BASE_URL=https://api.base-search.net/cgi-bin/BaseHttpSearchInterface.fcgi

# WorldCat (OCLC) — requires active OCLC membership contract; obtain keys at platform.worldcat.org
WORLDCAT_CLIENT_ID=
WORLDCAT_CLIENT_SECRET=
WORLDCAT_SEARCH_BASE_URL=https://americas.discovery.api.oclc.org/worldcat/search/v2
WORLDCAT_METADATA_BASE_URL=https://metadata.api.oclc.org

# Active enrichment providers (comma-separated). Add providers here when their
# API key is in place and the service module is ready.
# Full list when all are live: openalex,unpaywall,semantic_scholar,core,openaire,opencitations,lens_org,base,worldcat
ENRICHMENT_SOURCES=openalex,unpaywall

# Per-provider emergency kill switches (set to 'true' to disable without removing from ENRICHMENT_SOURCES)
OPENALEX_KILL_SWITCH=false
SEMANTIC_SCHOLAR_KILL_SWITCH=false
CORE_KILL_SWITCH=false
OPENAIRE_KILL_SWITCH=false
OPENCITATIONS_KILL_SWITCH=false
LENS_ORG_KILL_SWITCH=false
BASE_KILL_SWITCH=false
WORLDCAT_KILL_SWITCH=false

# Figshare API Configuration
FIGSHARE_BASE_URL=https://api.figshare.com/v2
FIGSHARE_API_TOKEN=your_figshare_personal_token

# OJS API Configuration (configure when instance is available)
OJS_BASE_URL=https://your-ojs-instance.com/api/v1
OJS_API_KEY=your_ojs_api_key