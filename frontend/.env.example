# Frontend environment template (shared across local/dev/staging/prod)
# Copy to frontend/.env and set values for the target environment.

# Public base URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_NODE_URL=http://localhost:3001

# Backend routing for Next.js server-side API handlers (BFF)
BACKEND_API_URL=http://localhost:5002/api
API_BASE_URL=http://localhost:5002/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:5002/api/v1
BACKEND_UPLOAD_ORIGIN=http://localhost:5002

# ORCID
NEXT_PUBLIC_ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=
NEXT_PUBLIC_ORCID_REDIRECT_URI=http://localhost:3001/callback/orcid
NEXT_PUBLIC_ORCID_AUTHORIZE_URL=https://sandbox.orcid.org/oauth/authorize
NEXT_PUBLIC_ORCID_TOKEN_URL=https://sandbox.orcid.org/oauth/token
NEXT_PUBLIC_ORCID_PUB_API_URL=https://pub.sandbox.orcid.org
NEXT_PUBLIC_ORCID_SCOPE=/authenticate

# GitHub
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://localhost:3001/callback/github
NEXT_PUBLIC_GITHUB_URL=https://github.com/login/oauth/authorize
NEXT_PUBLIC_GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
NEXT_PUBLIC_GITHUB_SCOPE=user:email

# Google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3001/callback/google

# SMTP (used by Next.js route handlers)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
